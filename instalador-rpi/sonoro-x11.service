[Unit]
Description=SONORO AV — X11 Display Session
After=systemd-udev-settle.service
Wants=systemd-udev-settle.service

[Service]
# IMPORTANTE: User=root requerido — Xorg sin logind seat no puede acceder a /dev/tty* y /dev/dri/
# con usuario no-root desde systemd. User=sonoro causa "Fatal server error: xf86OpenConsole".
User=root
Group=sonoro
Type=simple
Environment=HOME=/root
Environment=USER=sonoro
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=XDG_SESSION_TYPE=x11
ExecStartPre=/bin/rm -f /tmp/sonoro-x11-ready
ExecStart=/usr/bin/xinit /home/sonoro/sonoro-player/xinitrc.sh -- /usr/bin/X :0 vt1
ExecStopPost=/bin/rm -f /tmp/sonoro-x11-ready
Restart=always
RestartSec=5
KillMode=control-group

[Install]
WantedBy=graphical.target
